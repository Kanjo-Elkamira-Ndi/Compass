# Compass Advisor — Environment Variables
# Copy to .env and fill in values before running locally.

# ── Database (PostgreSQL 16 + pgvector) ──────────────────────────
DB_URL=jdbc:postgresql://localhost:5433/advisor
DB_USER=advisor
DB_PASSWORD=advisor_dev

# ── Redis ────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT (≥256-bit for HS256) ────────────────────────────────────
JWT_SECRET=dev-only-change-in-production-minimum-256-bits-required-for-hs256-algorithm

# ── AI Providers ─────────────────────────────────────────────────
AI_PROVIDER=openai
OPENAI_API_KEY=
GEMINI_API_KEY=

# ── Frontend (Vite) ─────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8080/api/v1
